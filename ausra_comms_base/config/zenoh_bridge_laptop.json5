// Zenoh bridge config for Laptop base station.
{
  plugins: {
    ros2dds: {
      domain: 0,
      namespace: "/",
      allow: {
        publishers: [],
        subscribers: [
          "/ausra_.*/map_compressed",
          "/ausra_.*/heartbeat",
          "/ausra_.*/local_pose",
          "/ausra_.*/current_goal",
        ],
        service_servers: [],
        service_clients: [],
        action_servers: [],
        action_clients: [],
      },
      reliable_routes_blocking: true,
    },
  },
  mode: "peer",
  listen: {
    endpoints: [
      "tcp/0.0.0.0:7447"
    ],
  },
  scouting: {
    multicast: {
      enabled: true,
      address: "224.0.0.224:7446",
      interface: "auto",
    },
    gossip: {
      enabled: true,
    },
  },
  connect: {
    endpoints: [
      "tcp/192.168.0.165:7447",
      "tcp/192.168.0.129:7447",
    ],
  },
}
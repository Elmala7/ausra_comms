// zenoh_bridge_laptop.json5 - Zenoh bridge config for Laptop base station.
// Laptop subscribes to compressed maps, poses, and heartbeats from Jetsons.
//
// COMMUNICATION IMPROVEMENTS (v2):
//   - /ausra_*/map_compressed: zlib-compressed maps (~200KB vs ~1MB raw)
//   - /ausra_*/map_relay: kept as fallback if compression is disabled
//   - map_decompressor_node on the laptop decompresses back to OccupancyGrid
{
  plugins: {
    ros2dds: {
      domain: 0,
      namespace: "/",
      allow: {
        publishers: [],
        subscribers: [
          "/ausra_.*/map_compressed",
          "/ausra_.*/map_relay",
          "/ausra_.*/pose_relay",
          "/ausra_.*/heartbeat",
        ],
        service_servers: [],
        service_clients: [],
        action_servers:  [],
        action_clients:  [],
      },
      reliable_routes_blocking: true,
    },
  },
  mode: "peer",
  listen: {
    endpoints: ["tcp/0.0.0.0:7447"],
  },
  scouting: {
    multicast: {
      enabled: true,
      address: "224.0.0.224:7446",
      interface: "auto",
    },
    gossip: {
      enabled: true,
    },
  },
  connect: {
    endpoints: [
      "tcp/192.168.1.33:7447",   // Jetson 1
      "tcp/192.168.1.42:7447",   // Jetson 2
    ],
  },
}
